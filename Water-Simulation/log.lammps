reset_timestep 0

#velocity all create 250.0 00001
velocity all create 250.0 12345 mom yes rot yes #Velocity for 250 K (mom yes - removes net linear momentum) (rot yes - removes net rotation)
thermo 200
thermo_style custom step temp etotal vol density

dump traj all atom 100 dump_water.lammpstrj

#Run
timestep 1.0
run 5000
